# Server
PORT=3000
CORS_ORIGINS=*
DRY_RUN=true

# Support inbox (issue reports)
SUPPORT_TO_EMAIL=techsupport@kingdomcitizen.app
EMAIL_FROM=KC Chatbot <noreply@kingdomcitizen.app>

# Option A — SendGrid (recommended if you already have it)
# Create an API key in SendGrid; verify your sender/domain first
SENDGRID_API_KEY=

# Option B — Resend
RESEND_API_KEY=

# Option C — SMTP (SendGrid SMTP: host smtp.sendgrid.net, user apikey, pass = API key)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional — also save tickets in Bubble
BUBBLE_API_URL=
BUBBLE_API_TOKEN=
BUBBLE_AUTH_HEADER=Authorization
