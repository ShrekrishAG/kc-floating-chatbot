# Server
PORT=3000
CORS_ORIGINS=*
DRY_RUN=true

# Bubble Backend Workflow (API Workflow)
# Example: https://your-app.bubbleapps.io/api/1.1/wf/create_support_issue
# For live apps with a custom domain, use that domain instead of bubbleapps.io
BUBBLE_API_URL=
BUBBLE_API_TOKEN=
# Optional: default is Authorization (Bearer token). Set e.g. X-API-Token if your workflow expects that.
BUBBLE_AUTH_HEADER=Authorization
