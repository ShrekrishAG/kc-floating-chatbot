# Server
PORT=3000
CORS_ORIGINS=*
DRY_RUN=true

# Support inbox (issue reports)
SUPPORT_TO_EMAIL=techsupport@kingdomcitizen.app
EMAIL_FROM=KC Chatbot <noreply@kingdomcitizen.app>

# Option A — Resend (https://resend.com) — verify kingdomcitizen.app first
RESEND_API_KEY=

# Option B — SMTP (Google Workspace / Microsoft 365 / Zoho / cPanel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=true   # only if using port 465

# Optional — also save tickets in Bubble
BUBBLE_API_URL=
BUBBLE_API_TOKEN=
BUBBLE_AUTH_HEADER=Authorization
